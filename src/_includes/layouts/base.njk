{% set currentUser = siteUsers[swimmerId] if swimmerId else null %}
{% set swimmer = swimmers[currentUser.swimmerId] if currentUser and currentUser.swimmerId else null %}
<!DOCTYPE html>
<!--[if IE 9]><html lang="en" class="ie9 no-js"><![endif]-->
<!--[if !IE]><!-->
<html lang="en">
<!--<![endif]-->
<head>
  <title>{{ title if title else "U.S. Masters Swimming" }}</title>
  {% include "partials/head-meta.njk" %}
  {% include "partials/head-js.njk" %}
  {% include "partials/head-css.njk" %}
  {% block pageCSS %}{% endblock %}
  {% if dev.env === "dev" %}{% for name, overlay in devOverlays %}{% if permalink in overlay.pages %}<link rel="stylesheet" href="{{ overlay.css }}">{% endif %}{% endfor %}{% endif %}
  {% if dev.env === "dev" %}<script type="application/json" id="dev-swimmers-data">{{ { "siteUsers": siteUsers, "swimmers": swimmers, "membershipTiers": membershipTiers } | dump | safe }}</script>{% endif %}
  {% if dev.env === "dev" and devSwimmerIds %}<script type="application/json" id="dev-swimmer-filter">{{ devSwimmerIds | dump | safe }}</script>{% endif %}
  {% if dev.env === "dev" and swimmerId %}<script type="application/json" id="dev-default-user">{{ swimmerId | dump | safe }}</script>{% endif %}
</head>
<body class="">
  <div id="main-container">
    <header class="header-static">
      {% include "partials/Navigation/MegaMainMenu.njk" %}
      {% block siteHeader %}{% endblock %}
    </header>
    <main role="main">
      {% block breadcrumb %}{% endblock %}
      {% block pageHeader %}{% endblock %}
      {% block content %}{% endblock %}
    </main>
  </div>
  {% include "partials/Navigation/Footer.njk" %}
  <script src="/js/megamenu.js" defer></script>
  {% block pageJS %}{% endblock %}
  {% if dev.env === "dev" %}
  {% for name, overlay in devOverlays %}{% if permalink in overlay.pages %}
  {% if overlay.defer === false %}<script src="{{ overlay.js }}"></script>{% else %}<script src="{{ overlay.js }}" defer></script>{% endif %}
  {% endif %}{% endfor %}
  {% endif %}
</body>
</html>
