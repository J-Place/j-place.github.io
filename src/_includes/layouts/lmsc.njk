{% block siteFooter %}
<footer>
  <div id="footerOverlay">
    <div class="container-fluid">
      <div class="row">
        <div class="footer-content">
          <div class="footer-left">
            <div class="footer-left__menu">
              <div class="row">
                <div class="col-xs-6 col-md-3">
                  <div class="footer-menu">
                    <h3 class="footer-menu__header">LMSC Info</h3>
                    <ul class="footer-menu__list list--nostyle">
                      <li class="footer-menu__list-item">
                        <a href="https://www.usms.org/club-central/start-a-club">How to Start a Club</a>
                      </li>
                      <li class="footer-menu__list-item">
                        <a href="https://www.usms.org/comp/sanction/request.php">Sanction an Event</a>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="col-xs-6 col-md-3">
                  <div class="footer-menu">
                    <h3 class="footer-menu__header">USMS Info</h3>
                    <ul class="footer-menu__list list--nostyle">
                      <li class="footer-menu__list-item">
                        <a href="https://www.usms.org/join-usms/membership-benefits">Membership Benefits</a>
                      </li>
                      <li class="footer-menu__list-item">
                        <a href="https://www.usms.org/about-usms/what-is-us-masters-swimming">What is Masters Swimming?</a>
                      </li>
                    </ul>
                  </div>
                </div>
                <div class="col-xs-6 col-md-3"></div>
                <div class="col-xs-6 col-md-3"></div>
              </div>
            </div>
          </div>
          <div class="footer-right">
            <div class="subscribe">
              <div>
                <h4 class="subscribe__header m-b-30"></h4>
                <p class="m-b-30"></p>
                <a class="btn btn-primary btn-lg text-uppercase" href="https://www.usms.org/login-to-registration-page">JOIN NOW</a>
              </div>
            </div>
            <ul class="nav nav-stacked">
              <li>
                <a href="https://www.usms.org/content/privacy">
                  <span>Privacy Policy</span>
                </a>
              </li>
            </ul>
            <small class="copyright">&copy; 2021 Ohio LMSC</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
