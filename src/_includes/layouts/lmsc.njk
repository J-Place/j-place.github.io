{% extends "layouts/base.njk" %}

{% block pageCSS %}
<link href="https://www.usms.org/styles/home.min.css" rel="stylesheet">
{% endblock %}

{% block localCSS %}
<link rel="stylesheet" href="/css/lmsc.css">
<link rel="stylesheet" href="/css/Common/sc-form.css">
<link rel="stylesheet" href="/css/Common/recaptcha-fpo.css">
{% endblock %}

{% block megamenuJS %}
<script src="/js/lmsc-nav.js" defer></script>
{% endblock %}

{% block pageJS %}
<script src="/js/image-slider.js" defer></script>
{% endblock %}

