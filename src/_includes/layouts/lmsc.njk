{% block siteHeader %}
<div class="carousel-container">
  <button class="carousel-previous-button" style="display:none;">
    <i class="fa-solid fa-chevron-left"></i>
  </button>
  <ul class="carousel list--nostyle">
    <li class="carousel__slide">
      <div class="carousel__slide-content">
        <h1 class="text-capitalize">Welcome to</h1>
        <p class="lead">Ohio LMSC</p>
        <a href="https://www.usms.org/join-usms/join-or-renew" class="text-capitalize text-center">Join Now</a>
      </div>
      <div class="carousel__slide-image--desktop">
        <div class="carousel__slide-image" style="background-image:url('https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/lightroom/bigstock-swimming-pool-under-water---53318314.jpg?rev=9e0462dd5d2b414598c89e0d6e087a82');"></div>
      </div>
      <div class="carousel__slide-image--mobile">
        <div class="carousel__slide-image" style="background-image:url('https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/lightroom/bigstock-swimming-pool-under-water---53318314.jpg?rev=9e0462dd5d2b414598c89e0d6e087a82');"></div>
      </div>
    </li>
  </ul>
  <button class="carousel-next-button" style="display:none;">
    <i class="fa-solid fa-chevron-right"></i>
  </button>
</div>
{% endblock %}

{% block content %}{{ content | safe }}{% endblock %}
