{#
  Generic Modal Component
  -----------------------
  Set these variables before including:

    modalId        — required: id on the outer .modal element
    modalModifier  — optional: extra class on .modal (e.g. "cta-modal--club-badge")
    modalSize      — optional: "sm" | "lg" | "xl" for .modal-dialog size
    modalCentered  — optional: true to vertically center the dialog
    modalTitleId   — optional: id on the <h5> (useful for aria-labelledby)
    modalTitle     — optional: title text; leave unset for JS-populated titles

    modalBody      — optional: body HTML
                     {% set modalBody %}...{% endset %}

    modalFooter    — optional: footer HTML
                     {% set modalFooter %}...{% endset %}

  Example:
    {% set modalId = "myModal" %}
    {% set modalSize = "lg" %}
    {% set modalCentered = true %}
    {% set modalBody %}
      <p>Some content</p>
    {% endset %}
    {% set modalFooter %}
      <button class="btn btn-primary" id="myModalConfirm" type="button">Continue</button>
    {% endset %}
    {% include "components/modal.njk" %}
#}

<div class="modal usms-modal-global{{ (' ' + modalModifier) if modalModifier }}"
     id="{{ modalId }}"
     tabindex="-1"
     role="dialog"
     aria-hidden="true"
     style="display:none;">
  <div class="modal-dialog{{ (' modal-dialog-centered') if modalCentered }}{{ (' modal-' + modalSize) if modalSize }}">
    <div class="modal-content">
      <div class="modal-header{{ ' modal-header--titled' if modalTitle }}">
        <h5 class="modal-title"{% if modalTitleId %} id="{{ modalTitleId }}"{% endif %}>{{ modalTitle if modalTitle }}</h5>
        <button type="button" class="btn-close js-modal-close" aria-label="Close"></button>
        {% if modalHeaderExtra %}{{ modalHeaderExtra | safe }}{% endif %}
      </div>
      {% if modalBody %}
      <div class="modal-body{{ (' ' + modalBodyClass) if modalBodyClass }}">
        {{ modalBody | safe }}
      </div>
      {% endif %}
      {% if modalFooter %}
      <div class="modal-footer">
        {{ modalFooter | safe }}
      </div>
      {% endif %}
    </div>
  </div>
</div>
