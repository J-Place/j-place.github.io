<div class="list-control">

  <div class="list-control-search">
    <div class="list-control-search__header">
      <span class="tag-list--title">Filters:</span>
      <div class="list-control-search--tags"></div>
      <i class="fa-solid fa-refresh fa-spin list-control-search--summary-loading" style="display:none;"></i>
      <div class="list-control-search--summary">
        Showing <strong>{{ clubItems | length }} Clubs</strong> within <strong>25 Miles</strong>
      </div>
    </div>
    <div class="list-control-search-mobile__toggle">Update Your Results</div>
    <div class="list-control-search__content form-group is-flex">
      <div class="list-control-search__input list-control-search__input--club-name">
        <label for="search-filter__club-name">Search by Club Name</label>
        <div class="input-group">
          <span class="help-block help-block--ClubName">Please Enter a Club Name</span>
          <input type="text" class="form-control" name="search-filter__club-name" placeholder="Club Name">
        </div>
      </div>
      <div class="list-control-search__input list-control-search__input--range">
        <label for="search-filter__range">Select a Range</label>
        <div class="input-group">
          <select id="search-filter__range" name="search-filter__range">
            <option value="10">10 Miles</option>
            <option value="25" selected>25 Miles</option>
            <option value="50">50 Miles</option>
            <option value="100">100 Miles</option>
            <option value="250">250 Miles</option>
            <option value="max">Nationwide</option>
          </select>
        </div>
      </div>
      <div class="list-control-search__input list-control-search__input--location">
        <label for="location">Search by City, State or Zip</label>
        <div class="input-group">
          <span class="help-block help-block--CityStateZip">Please enter a City, State or Zip</span>
          <div>
            <div class="map" style="display:none;"></div>
            <input type="text" class="google-places-input form-control" placeholder="Select city &amp; state or zip" name="location" id="location" autocomplete="off">
            <input type="hidden" class="google-places-input--zip" name="google-places-input--zip">
            <input type="hidden" class="google-places-input--lat" name="google-places-input--lat">
            <input type="hidden" class="google-places-input--lng" name="google-places-input--lng">
          </div>
        </div>
      </div>
      <div class="list-control-search__input list-control-search__input--button align-self-end">
        <div class="input-group">
          <button type="button" class="btn btn-primary" id="listSearchSubmit">Submit</button>
        </div>
      </div>
    </div>
  </div>

  <div class="list-control-filter">
    <div class="list-control-filter__header">
      <button class="toggle-filters">More Filters</button>
    </div>
    <div class="list-control-filter__content form-group is-flex">
      <div class="form-group is-flex">
        <div class="check-list check-list--certifications">
          {% set certifications = [
            { label: "Gold Club",                   value: "gc"   },
            { label: "ALTS Grant Program",          value: "sslf" },
            { label: "Certified Coach",             value: "cc"   },
            { label: "Certified ALTS Instructor",   value: "alts" }
          ] %}
          {% for cert in certifications %}
          <div class="input-group check-list-item">
            <label id="{{ cert.label | replace(' ', '') }}__label" class="checkbox-label" for="{{ cert.label | replace(' ', '') }}">
              <div class="checkbox-container">
                <input type="checkbox" name="{{ cert.label }}" id="{{ cert.label | replace(' ', '') }}" value="{{ cert.value }}">
                <span class="checkbox__placeholder"></span>
              </div>
              {{ cert.label }}
            </label>
          </div>
          {% endfor %}
        </div>
        <div class="check-list check-list--double">
          <div class="check-list check-list--facility-type">
            {% set facilityTypes = [
              { label: "Indoor",     value: "ip" },
              { label: "Outdoor",    value: "op" },
              { label: "Open Water", value: "ow" }
            ] %}
            {% for facility in facilityTypes %}
            <div class="input-group check-list-item">
              <label id="{{ facility.label | replace(' ', '') }}__label" class="checkbox-label" for="{{ facility.label | replace(' ', '') }}">
                <div class="checkbox-container">
                  <input type="checkbox" name="{{ facility.label }}" id="{{ facility.label | replace(' ', '') }}" value="{{ facility.value }}">
                  <span class="checkbox__placeholder"></span>
                </div>
                {{ facility.label }}
              </label>
            </div>
            {% endfor %}
          </div>
        </div>
        <div class="check-list check-list--pool-length">
          {% set poolLengths = [
            { label: "25 Meters", value: "25m" },
            { label: "25 Yards",  value: "25y" },
            { label: "50 Meters", value: "50m" },
            { label: "Other",     value: "other" }
          ] %}
          {% for pool in poolLengths %}
          <div class="input-group check-list-item">
            <label id="{{ pool.label | replace(' ', '') }}__label" class="checkbox-label" for="{{ pool.label | replace(' ', '') }}">
              <div class="checkbox-container">
                <input type="checkbox" name="{{ pool.label }}" id="{{ pool.label | replace(' ', '') }}" value="{{ pool.value }}">
                <span class="checkbox__placeholder"></span>
              </div>
              {{ pool.label }}
            </label>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <div class="list-control-view">
    <div class="list-control-view__header">
      <span class="toggle-list active">
        <button type="button" disabled>List</button>
      </span>
      <span class="toggle-map">
        <button type="button">Map</button>
      </span>
    </div>
  </div>

</div>
