<section class="section section-full swimmer-stats">
  <div class="usms-container">
    <div class="row">
    <div class="col-xs-12">
      <div class="swimmer-stats__profile">
        <div class="swimmer-stats__name">
          <h2 id="swimmerName"></h2>
        </div>
        <div class="swimmer-stats__meta" id="swimmerMeta"></div>
        <form class="swimmer-stats__lookup" id="swimmerLookup" autocomplete="off">
          <span class="swimmer-stats__lookup-label">Swimmer Lookup</span>
          <div class="swimmer-stats__lookup-fields">
            <span class="swimmer-stats__lookup-error" id="swimmerLookupError" hidden>ID not found</span>
            <input class="swimmer-stats__lookup-input" type="text" name="id" placeholder="Swimmer ID" aria-label="USMS Swimmer ID" maxlength="10" spellcheck="false">
            <button class="swimmer-stats__lookup-btn" type="submit">View</button>
            <button class="swimmer-stats__compare-btn" type="button" id="swimmerCompareBtn">Compare</button>
          </div>
        </form>
      </div>
      <div class="swimmer-stats__controls">

        <div class="swimmer-stats__filter-group course-group">
          <span class="swimmer-stats__filter-label">Course</span>
          <div class="swimmer-stats__course-filters" role="group" aria-label="Filter by course">
            <button class="swimmer-stats__btn swimmer-stats__course-btn is-active" data-course="all">All</button>
          </div>
        </div>

        <div class="swimmer-stats__filter-group age-group">
          <span class="swimmer-stats__filter-label">Age Group</span>
          <div class="swimmer-stats__age-filters" role="group" aria-label="Filter by age group">
            <button class="swimmer-stats__btn swimmer-stats__age-btn is-active" data-age="all">All</button>
          </div>
        </div>

        <div class="swimmer-stats__filter-group event-group">
          <span class="swimmer-stats__filter-label">Event</span>
          <div class="swimmer-stats__event-controls">
            <button class="swimmer-stats__btn swimmer-stats__event-all-btn is-active" data-event="all">All</button>
            <select class="swimmer-stats__event-select" aria-label="Filter by event">
            </select>
          </div>
        </div>

        <div class="swimmer-stats__filter-group pb-group">
          <span class="swimmer-stats__filter-label">Personal Best</span>
          <button class="swimmer-stats__btn swimmer-stats__pb-btn">Show</button>
        </div>

      </div>
      <div class="swimmer-stats__results"></div>
    </div>
    </div>
  </div>

  <!-- Compare modal -->
  <div class="swimmer-stats__chart-modal" id="swimmerCompareModal" role="dialog" aria-modal="true" aria-label="Compare swimmers" hidden>
    <div class="swimmer-stats__chart-modal-inner swimmer-stats__compare-modal-inner">
      <div class="swimmer-stats__chart-modal-hdr">
        <h3 class="swimmer-stats__chart-modal-title" id="swimmerCompareTitle">Compare Swimmers</h3>
        <button class="swimmer-stats__chart-close" id="swimmerCompareClose" aria-label="Close compare">&times;</button>
      </div>
      <div class="swimmer-stats__chart-wrap" id="swimmerCompareChartWrap">
        <canvas id="swimmerCompareChart"></canvas>
      </div>
    </div>
  </div>
  <div class="swimmer-stats__chart-backdrop" id="swimmerCompareBackdrop" hidden></div>

  <!-- Progress chart modal -->
  <div class="swimmer-stats__chart-modal" id="swimmerChartModal" role="dialog" aria-modal="true" aria-label="Event progress chart" hidden>
    <div class="swimmer-stats__chart-modal-inner">
      <div class="swimmer-stats__chart-modal-hdr">
        <h3 class="swimmer-stats__chart-modal-title" id="swimmerChartTitle"></h3>
        <button class="swimmer-stats__chart-close" aria-label="Close chart">&times;</button>
      </div>
      <div class="swimmer-stats__chart-wrap">
        <canvas id="swimmerProgressChart"></canvas>
      </div>
    </div>
  </div>
  <div class="swimmer-stats__chart-backdrop" id="swimmerChartBackdrop" hidden></div>

</section>
