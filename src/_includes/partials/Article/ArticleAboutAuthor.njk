<div class="article-author bg-ltblue">
  <div class="article-author__header">
    <div class="article-author__image-container bg-gray">
      <img class="article-author__image" src="{{ authorImage }}" alt="{{ authorName }}">
    </div>
    <h3 class="text-capitalize article-author__title"><small>About the Author</small><br>{{ authorName }}</h3>
  </div>
  <div class="article-author__content">
    <div class="html-container">
      {{ authorBio | safe }}
    </div>
  </div>
</div>
