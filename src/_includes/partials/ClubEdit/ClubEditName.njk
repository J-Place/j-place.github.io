<form id="form-name">
<div class="section section-name" id="club-name">
    <h3 class="section__header" data-target="#club-name__content" data-toggle="collapse" aria-expanded="false" aria-controls="club-name__content">
        <span class="section__number">1</span>Club Name
    </h3>
    <span class="section__edit"><button class="section__edit-btn section__edit-btn--name" type="button" onclick="editClubName(event)"></button></span>
    <div class="section__content collapse" id="club-name__content" data-parent="#accordion">
        <div class="row">
            <div class="col-xs-12 col-sm-8 col-md-5">
                <div class="input-group select-lmsc required">
                    <label for="selectLmsc">
                        Select Your Local Chapter (LMSC)
                        <a tabindex="0"
                           class="popover-link"
                           role="button"
                           data-bs-toggle="tooltip"
                           data-bs-trigger="focus"
                           data-bs-html="true"
                           data-bs-placement="top"
                           title="Your LMSC is a regional governing body that provides certain benefits to USMS members, a map of USMS LMSC&#39;s can be found &lt;a href=&quot;https://www.usms.org/lmsc/&quot;&gt;here&lt;/a&gt;">
                             <span class="icon-help"></span>
                        </a>
                    </label>
                    <select class="form-control" id="selectLmsc" name="SelectedLmscSFId" required>
                        <option value="">Select LMSC</option>
                        <option value="a0x3h000001SQWpAAO">Adirondack</option>
                        <option value="a0x3h000001SQWqAAO">Alaska</option>
                        <option value="a0x3h000001SQWrAAO">Allegheny Mountain</option>
                        <option value="a0x3h000001SQWsAAO">Arizona</option>
                        <option value="a0x3h000001SQWtAAO">Arkansas</option>
                        <option value="a0x3h000001SQWuAAO">Colorado</option>
                        <option value="a0x3h000001SQWvAAO">Connecticut</option>
                        <option value="a0x3h000001SQWwAAO">Delaware Valley</option>
                        <option value="a0x3h000001SQWxAAO">Florida</option>
                        <option value="a0x3h000001SQWyAAO">Florida Gold Coast</option>
                        <option value="a0x3h000001SQWzAAO">Georgia</option>
                        <option value="a0x3h000001SQX0AAO">Gulf</option>
                        <option value="a0x3h000001SQX1AAO">Hawaii</option>
                        <option value="a0x3h000001SQX2AAO">Illinois</option>
                        <option value="a0x3h000001SQX3AAO">Indiana</option>
                        <option value="a0x3h000001SQX4AAO">Inland Northwest</option>
                        <option value="a0x3h000001SQX5AAO">Iowa</option>
                        <option value="a0x3h000001SQX6AAO">Kentucky</option>
                        <option value="a0x3h000001SQX7AAO">Lake Erie</option>
                        <option value="a0x3h000001SQX8AAO">Maryland</option>
                        <option value="a0x3h000001SQX9AAO">Metropolitan</option>
                        <option value="a0x3h000001SQXAAA4">Michigan</option>
                        <option value="a0x3h000001SQXBAA4">Minnesota</option>
                        <option value="a0x3h000001SQXCAA4">Missouri Valley</option>
                        <option value="a0x3h000001SQXDAA4">Montana</option>
                        <option value="a0x3h000001SQXEAA4">Nebraska</option>
                        <option value="a0x3h000001SQXFAA4">New England</option>
                        <option value="a0x3h000001SQXGAA4">New Jersey</option>
                        <option value="a0x3h000001SQXHAA4">New Mexico</option>
                        <option value="a0x3h000001SQXIAA4">Niagara</option>
                        <option value="a0x3h000001SQXJAA4">North Carolina</option>
                        <option value="a0x3h000001SQXKAA4">North Dakota</option>
                        <option value="a0x3h000001SQXLAA4">North Texas</option>
                        <option value="a0x3h000001SQXMAA4">Ohio</option>
                        <option value="a0x3h000001SQXNAA4">Oklahoma</option>
                        <option value="a0x3h000001SQXOAA4">Oregon</option>
                        <option value="a0x3h000001SQXPAA4">Ozark</option>
                        <option value="a0x3h000001SQXQAA4">Pacific</option>
                        <option value="a0x3h000001SQXRAA4">Pacific Northwest</option>
                        <option value="a0x3h000001SQXSAA4">Potomac Valley</option>
                        <option value="a0x3h000001SQXTAA4">San Diego-Imperial</option>
                        <option value="a0x3h000001SQXUAA4">Snake River</option>
                        <option value="a0x3h000001SQXVAA4">South Carolina</option>
                        <option value="a0x3h000001SQXWAA4">South Dakota</option>
                        <option value="a0x3h000001SQXXAA4">South Texas</option>
                        <option value="a0x3h000001SQXYAA4">Southeastern</option>
                        <option value="a0x3h000001SQXZAA4">Southern</option>
                        <option value="a0x3h000001SQXaAAO">Southern Pacific</option>
                        <option value="a0x3h000001SQXbAAO">Utah</option>
                        <option value="a0x3h000001SQXcAAO">Virginia</option>
                        <option value="a0x3h000001SQXeAAO">Wisconsin</option>
                    </select>
                    <span class="help-block help-block--SelectLmsc">LMSC is required.</span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-xs-12 col-sm-8 col-md-5">
                <div class="input-group club-name required">
                    <label for="clubName">
                        Club Name
                        <span class="icon-help"
                              data-bs-toggle="tooltip"
                              data-bs-placement="top"
                              title=""
                              data-bs-container="body"></span>
                    </label>
                    <input class="form-control club-name__input" id="clubName" maxlength="80" minlength="3" name="ClubName" required type="text" value="" />
                    <span class="help-block help-block--ClubName">Club name is required.</span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-xs-12 col-sm-8 col-md-5">
                <div class="input-group club-abbr required">
                    <label for="clubAbbr">
                        Club Abbreviation
                        <span class="icon-help" data-bs-toggle="tooltip" data-bs-placement="top" title="Select a club abbreviation that is 2 to 5 characters. The abbreviation must be unique. If the abbreviation you selected is not available, you will be prompted to select another one." data-container="body"></span>
                    </label>
                    <input class="form-control club-name__input text-uppercase" id="clubAbbr" maxlength="5" minlength="2" name="ClubAbbr" pattern="[A-Za-z]" required type="text" value="" />
                    <span class="help-block help-block--ClubAbbr">Club abbreviation is required</span>
                </div>
            </div>
        </div>

        {% set modalId = "modalClubName" %}
        {% set modalTitle = "Club Abbreviation" %}
        {% set modalBody %}
        <p>The abbreviation you have selected is already in use by another club. Please pick another one.</p>
        {% endset %}
        {% set modalFooter = "" %}
        {% include "components/modal.njk" %}

        <div class="row">
            <div class="section__controls">
                <button class="btn save-section" id="saveClubName" type="button" onclick="saveName(event)">Save &amp; Continue</button>
            </div>
        </div>
    </div>
</div>
</form>
