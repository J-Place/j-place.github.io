<div class="renew__form-container m-b-30">
	<div class="row">
		<div class="col-xs-12">
			<div class="renew__header">
				<p>Welcome to U.S. Masters Swimming. Let's finish your registration.</p>
			</div>
			<div class="renew__form-body">
				<div id="registration_form">
					<div class="full-registration-form" data-membership-level="{{ swimmer.membership.tier if swimmer else '' }}">

						{% include "partials/registration-contact.njk" %}

						{% include "partials/registration-club.njk" %}

						{% include "partials/registration-interests.njk" %}

						{% include "partials/registration-liability.njk" %}

						<div class="registration-step registration-step--payment">
							<form class="form-membership-length form-horizontal">
								<input type="hidden" name="current-reg-year" value="2026">
								<input type="hidden" name="magazineAddonPrice" value="10">

								{% include "partials/registration-participation.njk" %}

								{% include "partials/registration-membership-options.njk" %}

								{% include "partials/registration-competition-cert.njk" %}

								{% include "partials/registration-vsa.njk" %}

								{% include "partials/donations.njk" %}

								{% include "partials/registration-payment.njk" %}

							</form>
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>
