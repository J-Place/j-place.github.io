{% macro productTile(option, key) %}
<div class="product-option {{ option.extraClasses }} product-option_{{ option.modifier }}"{% if key %} data-product-key="{{ key }}"{% endif %}{% if option.termsKey %} data-terms-key="{{ option.termsKey }}"{% endif %}{% if option.requiresProduct %} data-requires-product="{{ option.requiresProduct }}"{% endif %}>
	<p class="product-name">{{ option.name | safe }}</p>
	<p class="product-price">${{ option.price | price }}</p>
	<div class="product-summary">
		{% if option.bulletList %}
		<ul class="payment-bullets">
			{% for item in option.bulletList %}
			<li>{{ item }}</li>
			{% endfor %}
		</ul>
		{% elif option.summary %}
		<p>{{ option.summary | safe }}</p>
		{% endif %}
	</div>
	{% if option.type === "stroke-select" %}
	<div class="form-group">
		<select name="StrokeSelect" id="strokeSelect" class="form-control">
			<option selected="" value="0" disabled="">Select a stroke</option>
			<option value="Freestyle">Freestyle</option>
			<option value="Breaststroke">Breaststroke</option>
			<option value="Backstroke">Backstroke</option>
			<option value="Butterfly">Butterfly</option>
			<option value="Starts and Turns">Starts/Turns</option>
		</select>
	</div>
	{% endif %}
	<button class="btn btn-outline btn-md add-on"{% if option.type === "stroke-select" %} disabled=""{% endif %}>Add</button>
</div>
{% endmacro %}

<div class="card add-on-products">
	{% if productOptionGroups %}
		{# Multi-row: one product-group row per group, all within the same card #}
		{% for group in productOptionGroups %}
		{% set roleHidden = group.requiresRole and not swimmer[group.requiresRole] %}
		{% if group.label %}<h3 class="addons__form-header"{% if group.requiresRole %} data-requires-role="{{ group.requiresRole }}"{% endif %}{% if roleHidden %} style="display:none"{% endif %}>{{ group.label }}</h3>{% endif %}
		<div class="product-group"{% if group.requiresRole %} data-requires-role="{{ group.requiresRole }}"{% endif %}{% if roleHidden %} style="display:none"{% endif %}>
			{% for key in group.keys %}
			{% set option = products[key] %}
			{% if option and option.active !== false %}
			{{ productTile(option, key) }}
			{% endif %}
			{% endfor %}
		</div>
		{% endfor %}
	{% else %}
		{# Single-row fallback: uses productOptionKeys #}
		<div class="product-group">
			{% for key in productOptionKeys %}
			{% set option = products[key] %}
			{% if option and option.active !== false %}
			{{ productTile(option, key) }}
			{% endif %}
			{% endfor %}
		</div>
	{% endif %}
	<h4 class="card__total">
		Product Total: <span class="total-product card__total--amount">$0.00</span>
	</h4>
</div>
