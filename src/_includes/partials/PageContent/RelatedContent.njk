<div class="section section-full bg-blue p-tb-30">
  <div class="usms-container">
    <div class="row">
      <div class="related-content">
        <h3 class="related-content__header">Related Articles</h3>
        <div class="col-xs-12">
          <div class="related-content__container">
            {% for article in relatedArticles %}
            <div class="latest-content__article">
              <div class="latest-content__image-container">
                <a href="{{ article.url }}">
                  <div class="latest-content__image" style="background-image: url('{{ article.imageUrl }}');"></div>
                </a>
              </div>
              <div class="latest-content__type text-uppercase"><span>Article</span></div>
              <div class="latest-content__detail">
                <a href="{{ article.url }}">
                  <h3 class="latest-content__detail-header text-primary">{{ article.title }}</h3>
                </a>
              </div>
              <div class="latest-content__author">
                <div class="latest-content__author-image-container">
                  <img src="{{ article.authorImage }}" alt="author">
                </div>
                <p class="latest-content__author-name">{{ article.authorName }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
