{% extends "layouts/base.njk" %}
{% set title = "USMS Mockup Index" %}
{% block content %}
<main>
<div class="section section-full">
  <div class="usms-container" style="margin: 4rem auto 6rem;">
    <div class="row">
      <div class="col-lg-4">
        <h5>Work in Progress</h5>
        <ul style="margin-top: 1rem; list-style-type: none; padding-left: 0;">
          <li style="padding: 3px 0; font-size: 15px;"><a href="/public/">Original Public Index</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/home/">Mockup Site Homepage</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/account/my-account.html">My Account</a></li>

          <li style="padding: 3px 0; font-size: 15px;"><a href="/join-usms/join-or-renew-tms/">Join or Renew (TMS)</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/event-results/swimmer/">Swimmer Results</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/events/event-central/usms-measured-pools/">USMS Measured Pools</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/about/usms-style-guide.html">USMS Style Guide</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/events/event-central/event-dashboard.html">Event Dashboard</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/events/event-central/event-dashboard/event-add.html">Event Add</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/events/event-central/event-dashboard/event-edit.html">Event Edit</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/account/myusmslogin/">Log In</a></li>

          <li style="padding: 3px 0; font-size: 15px;"><a href="/lmsc/florida-lmsc.html">Florida LMSC</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/volunteer-central/committee-chair-contact.html">Committee Chair Contact</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/about/contact-lmsc.html">Contact Your LMSC</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/registration/registration-receipt.html">Registration Receipt</a></li>
          <li style="padding: 3px 0; font-size: 15px;"><a href="/fitness-and-training/articles-and-videos/articles/masters-swimming-training-plan-for-former-competitive-swimmers/">Article — Masters Swimming Training Plan</a></li>
        </ul>
      </div>
      <div class="col-lg-8">
        <h5>Snapshots</h5>
        <ul style="margin-top: 1rem; list-style-type: none; padding-left: 0; max-height: 480px; overflow-y: auto; padding-right: 1rem;">
          {% for snap in snapshots %}
          <li style="padding: 3px 0; font-size: 15px;">
            <a href="{{ snap.url }}">{{ snap.label }} — {{ snap.displayDate }}</a>{% if snap.notes %} <span style="color: #888; font-size: 13px;">({{ snap.notes }})</span>{% endif %}
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</div>
</main>
{% endblock %}
