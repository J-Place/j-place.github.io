{% extends "layouts/base.njk" %}

{% block pageCSS %}
<link rel="stylesheet" href="https://www.usms.org/styles/sanctions.min.css">
{% endblock %}

{% block pageJS %}
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"></script>
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyA-xsYw_7sGTv8wWeK-WrAhQb4efLuZ7Bc&libraries=places"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.12/jquery.mask.min.js"></script>
<script src="https://www.usms.org/scripts/sanctions.min.js"></script>
{% endblock %}

{% block breadcrumb %}
{% include "partials/Common/Breadcrumb.njk" %}
{% endblock %}

{% block pageHeader %}
<div class="section section-full bg-gray p-mh-500">
  <div class="usms-container p-tb-10">
    <div class="row">
      <div class="col-xs-12">
        <header class="page-title">
          <h1>Add a New Event</h1>
        </header>
      </div>
    </div>
  </div>
{% endblock %}

{% block content %}

{% set modalId = "modalSanctionedRecognized" %}
{% set modalModifier = "meet-announcement-status" %}
{% set modalTitle = "Event Documents Ready?" %}
{% set modalBody %}
<div class="input-group radio-group">
  <div class="input-group radio-group">
    <label class="radio-label" for="meetAnnouncementNo">
      <div class="radio-container">
        <input type="radio" name="MeetAnnouncement" id="meetAnnouncementNo" value="meetAnnouncementNo">
        <span class="radio__placeholder"></span>
      </div>
      I have my meet announcement for a pool event or my safety plan application for an open water event done. I have spoken with an LMSC representative about the event date. I am ready to apply for my sanction/recognition.
    </label>
  </div>
  <div class="input-group radio-group">
    <label class="radio-label" for="meetAnnouncementYes">
      <div class="radio-container">
        <input type="radio" name="MeetAnnouncement" id="meetAnnouncementYes" value="meetAnnouncementYes">
        <span class="radio__placeholder"></span>
      </div>
      I do not have my meet announcement for a pool event or my safety plan application for an open water event complete. I want to create a Calendar Listing and will apply for a sanction/recognition once I have all my information.
    </label>
  </div>
  <span class="help-block help-block--MeetAnnouncement">Please indicate meet announcement status</span>
</div>
{% endset %}
{% set modalFooter %}
<button class="btn btn-lg btn-primary" id="confirmMeetAnnouncement" type="button">Continue</button>
{% endset %}
{% include "components/modal.njk" %}

<div class="usms-container message__container p-tb-10">
  <div class="row event-status-options">
    <div class="col-xs-12">
      <h3 class="add-club-choice__title">Below, you can apply for an event sanction/recognition, add a future event to the calendar, or request a listing for other types of events.</h3>
    </div>

    <div class="col-xs-12 col-lg-4">
      <div>
        <button class="btn btn-md btn-outline" id="btnSanctionedRecognized" data-bs-toggle="modal" data-bs-target="#modalSanctionedRecognized" type="button">+ Sanction/Recognition</button>
        <h6>Sanction/Recognition</h6>
      </div>
      <div>
        <p>USMS sanctions require all participants to be <a href="/join-usms/join-or-renew-tms/">USMS members</a>&nbsp;(or&nbsp;<a href="https://www.usms.org/volunteer-central/guide-to-local-operations/lmsc-operations/registration/registration-procedures/one-events">one-event members</a>, if applicable). USMS recognition allows USMS members' results to count as official times, even if not all participants are members. USMS insurance covers sanctioned events, but not recognized.
          <a href="/volunteer-central/guide-to-local-operations/event-management">More details here &gt;</a>
        </p>
      </div>
    </div>

    <div class="col-xs-12 col-lg-4">
      <div>
        <a href="/events/event-central/event-dashboard/event-edit.html?rt=cl" class="btn btn-md btn-outline" id="btnCalendarListing">+ Calendar Listing</a>
        <h6>Calendar Listing</h6>
      </div>
      <div>
        <p>Any event that will apply for a USMS sanction/recognition in the future but wants to be on the USMS Calendar of Events now to raise awareness.</p>
      </div>
    </div>

    <div class="col-xs-12 col-lg-4">
      <div>
        <a href="/events/event-central/event-dashboard/event-edit.html?rt=oe" class="btn btn-md btn-outline" id="btnNonSanctionedRecognized">+ Other</a>
        <h6>Other Event</h6>
      </div>
      <div>
        <p>Any event that is not applying for a USMS sanction/recognition. Examples of these events: a pool or open water clinic, virtual events, a kick for time event, a fun relay event, or an event sanctioned by another governing body.</p>
      </div>
    </div>

  </div>
</div>
</div>
{% endblock %}
