---
{% extends "layouts/base.njk" %}

{% block pageCSS %}
<link rel="stylesheet" href="https://www.usms.org/styles/clubDetail.min.css">
<link rel="stylesheet" href="/css/Club/contact-non-members.css">
{% endblock %}

{% block breadcrumb %}
{% include "partials/Common/Breadcrumb.njk" %}
{% endblock %}

{% block pageHeader %}
<div class="section section-full bg-gray">
  <div class="usms-container p-tb-10">
    <div class="row">
      <div class="col-xs-12">
        <header class="page-title">
          <h1>Potential Members</h1>
          <h2 id="nonmembers-club-name" style="display:none"></h2>
        </header>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block content %}
<script type="application/json" id="potential-local-data">{{ potentialMembersLocal.potentialMembers | dump | safe }}</script>
<script type="application/json" id="clubs-local-data">{{ clubsLocal.clubs | dump | safe }}</script>
<script type="application/json" id="members-local-data">{{ membersLocal.members | dump | safe }}</script>

<div class="section section-full bg-gray">
  <div class="usms-container form__container p-tb-10">

    <div id="nonmembers-no-club" class="nonmembers-notice" style="display:none;">
      <p>No club selected. Please return to the <a href="/club-central/club-dashboard.html">Club Dashboard</a>.</p>
    </div>

    <div id="nonmembers-content">
      <p class="nonmembers-summary">This list shows everyone who has contacted USMS about your club, plus expired members due for renewal outreach.</p>
      <div class="nonmembers-col">
        <div class="nonmembers-col__header">
          <div class="nonmembers-col__name">
            <h3 class="nonmembers-col__title">Contact Queue</h3>
            <p class="nonmembers-col__subtitle">(<span id="recent-count">0</span> active)</p>
          </div>
          <div class="nonmembers-col__controls">
            <div class="nonmembers-filter" role="group" aria-label="Filter inbox">
              <span class="nonmembers-filter__label">Source:</span>
              <button class="nonmembers-filter__btn is-active" data-filter="all">All</button>
              <button class="nonmembers-filter__btn" data-filter="trial">Trial</button>
              <button class="nonmembers-filter__btn" data-filter="club">Club Page</button>
              <button class="nonmembers-filter__btn" data-filter="expired">Expired</button>
            </div>
            <button id="sort-dir" class="nonmembers-sort-dir" aria-label="Sort ascending">
              <span class="nonmembers-sort-icon">
                <i class="fas fa-sort nonmembers-sort-base" aria-hidden="true"></i>
                <i class="fas fa-sort-up nonmembers-sort-overlay" aria-hidden="true"></i>
              </span>
            </button>
          </div>
        </div>
        <div class="nonmembers-active" id="recent-active"></div>
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block pageJS %}
<script src="/js/contact-non-members-read-only.js" defer></script>
{% endblock %}
