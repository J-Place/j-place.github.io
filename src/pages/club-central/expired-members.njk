---
permalink: /club-central/expired-members.html
title: Manage Potential Members | U.S. Masters Swimming
pageTitle: Manage Potential Members
breadcrumbs:
  - url: "/home"
    label: "Home"
  - url: "/club-central"
    label: "Club Central"
  - url: "/club-central/club-dashboard.html"
    label: "Club Dashboard"
  - url: "/club-central/club-dashboard/club-manage.html"
    label: "Manage Club"
breadcrumbTitle: "Manage Potential Members"
---
{% extends "layouts/base.njk" %}

{% block pageCSS %}
<link rel="stylesheet" href="https://www.usms.org/styles/clubDetail.min.css">
<link rel="stylesheet" href="/css/Club/contact-non-members.css">
{% endblock %}

{% block breadcrumb %}
{% include "partials/Common/Breadcrumb.njk" %}
{% endblock %}

{% block pageHeader %}
<div class="section section-full bg-gray">
  <div class="usms-container p-tb-10">
    <div class="row">
      <div class="col-xs-12">
        <header class="page-title">
          <h1>Manage Potential Members</h1>
          <h2 id="nonmembers-club-name" style="display:none"></h2>
        </header>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block content %}
<script type="application/json" id="potential-local-data">{{ potentialMembersLocal.potentialMembers | dump | safe }}</script>
<script type="application/json" id="clubs-local-data">{{ clubsLocal.clubs | dump | safe }}</script>
<script type="application/json" id="members-local-data">{{ membersLocal.members | dump | safe }}</script>

<div class="section section-full bg-gray">
  <div class="usms-container form__container p-tb-10">

    <div id="nonmembers-no-club" class="nonmembers-notice" style="display:none;">
      <p>No club selected. Please return to the <a href="/club-central/club-dashboard.html">Club Dashboard</a>.</p>
    </div>

    <div id="nonmembers-content">
      <p class="nonmembers-summary">This list shows everyone who has contacted USMS about your club, plus expired members due for renewal outreach.</p>
      <div class="nonmembers-col">
        <div class="nonmembers-col__header">
          <div class="nonmembers-col__name">
            <h3 class="nonmembers-col__title">Contact Queue</h3>
            <p class="nonmembers-col__subtitle">(<span id="recent-count">0</span> active)</p>
          </div>
          <!--
          <div class="nonmembers-col__controls">
            <div class="nonmembers-filter" role="group" aria-label="Filter inbox">
              <span class="nonmembers-filter__label">Source:</span>
              <button class="nonmembers-filter__btn is-active" data-filter="all">All</button>
              <button class="nonmembers-filter__btn" data-filter="trial">Trial</button>
              <button class="nonmembers-filter__btn" data-filter="club">Club Page</button>
              <button class="nonmembers-filter__btn" data-filter="expired">Expired</button>
            </div>
            <button id="sort-dir" class="nonmembers-sort-dir" aria-label="Sort ascending">
              <span class="nonmembers-sort-icon">
                <i class="fas fa-sort nonmembers-sort-base" aria-hidden="true"></i>
                <i class="fas fa-sort-up nonmembers-sort-overlay" aria-hidden="true"></i>
              </span>
            </button>
          </div>
          -->
        </div>
        <div class="nonmembers-active" id="recent-active"></div>
        <div class="nonmembers-responded">
          <div class="nonmembers-responded__header">
            <div>
              <h4 class="nonmembers-col__title">Replied to</h4>
              <p class="nonmembers-col__subtitle">(archived after 90 days)</p>
            </div>
            <!--
            <button id="responded-sort-dir" class="nonmembers-sort-dir" aria-label="Sort descending">
              <span class="nonmembers-sort-icon">
                <i class="fas fa-sort nonmembers-sort-base" aria-hidden="true"></i>
                <i class="fas fa-sort-down nonmembers-sort-overlay" aria-hidden="true"></i>
              </span>
            </button>
            -->
          </div>
          <div class="nonmembers-responded__list" id="recent-responded-list"></div>
        </div>
      </div>
    </div>

  </div>
</div>

{% set modalId = "contact-expired-modal" %}
{% set modalSize = "lg" %}
{% set modalTitle = "Contact Member" %}
{% set modalBody %}
<div class="reply-msg">
  <div class="reply-msg__row">
    <span class="reply-msg__label">Date</span>
    <span class="reply-msg__value" id="contact-exp-date"></span>
  </div>
  <div class="reply-msg__row">
    <span class="reply-msg__label">To</span>
    <span class="reply-msg__value" id="contact-exp-to"></span>
  </div>
  <div class="reply-msg__row">
    <span class="reply-msg__label">From</span>
    <span class="reply-msg__value" id="contact-exp-from"></span>
  </div>
  <div class="reply-msg__row reply-msg__row--field">
    <label class="reply-msg__label" for="contact-exp-subject">Subject</label>
    <input type="text" id="contact-exp-subject" class="form-control reply-msg__input">
  </div>
  <div class="reply-msg__row reply-msg__row--field reply-msg__row--message">
    <label class="reply-msg__label" for="contact-exp-body">Message</label>
    <textarea id="contact-exp-body" class="form-control reply-msg__textarea" rows="6"></textarea>
  </div>
</div>
{% endset %}
{% set modalFooter %}
<button type="button" class="btn btn-md btn-link" id="contact-exp-cancel-btn">Cancel</button>
<button type="button" class="btn btn-md btn-primary" id="contact-exp-send-btn" disabled>Send</button>
{% endset %}
{% include "components/modal.njk" %}

{% set modalId = "original-modal" %}
{% set modalSize = "lg" %}
{% set modalTitle = "Original Message" %}
{% set modalBody %}
<div class="original-msg">
  <div class="original-msg__row">
    <span class="original-msg__label">From</span>
    <span class="original-msg__value" id="orig-name"></span>
  </div>
  <div class="original-msg__row">
    <span class="original-msg__label">Email</span>
    <span class="original-msg__value" id="orig-email"></span>
  </div>
  <div class="original-msg__row" id="orig-phone-row">
    <span class="original-msg__label">Phone</span>
    <span class="original-msg__value" id="orig-phone"></span>
  </div>
  <div class="original-msg__row">
    <span class="original-msg__label">USMS Member</span>
    <span class="original-msg__value" id="orig-member"></span>
  </div>
  <div class="original-msg__row">
    <span class="original-msg__label">Interest</span>
    <span class="original-msg__value" id="orig-interest"></span>
  </div>
  <div class="original-msg__row original-msg__row--message">
    <span class="original-msg__label">Message</span>
    <span class="original-msg__value" id="orig-body"></span>
  </div>
</div>
{% endset %}
{% set modalFooter %}
<button type="button" class="btn btn-md btn-outline" disabled>Message</button>
<button type="button" class="btn btn-md btn-primary" id="orig-reply-btn">Reply</button>
{% endset %}
{% include "components/modal.njk" %}

{% set modalId = "reply-modal" %}
{% set modalSize = "lg" %}
{% set modalTitle = "Reply to Message" %}
{% set modalBody %}
<div class="reply-msg">
  <div class="reply-msg__row">
    <span class="reply-msg__label">Date</span>
    <span class="reply-msg__value" id="reply-date"></span>
  </div>
  <div class="reply-msg__row">
    <span class="reply-msg__label">To</span>
    <span class="reply-msg__value" id="reply-to"></span>
  </div>
  <div class="reply-msg__row">
    <span class="reply-msg__label">From</span>
    <span class="reply-msg__value" id="reply-from"></span>
  </div>
  <div class="reply-msg__row reply-msg__row--field">
    <label class="reply-msg__label" for="reply-subject">Subject</label>
    <input type="text" id="reply-subject" class="form-control reply-msg__input">
  </div>
  <div class="reply-msg__row reply-msg__row--field reply-msg__row--message">
    <label class="reply-msg__label" for="reply-body">Message</label>
    <textarea id="reply-body" class="form-control reply-msg__textarea" rows="6"></textarea>
  </div>
</div>
{% endset %}
{% set modalFooter %}
<button type="button" class="btn btn-md btn-outline" id="reply-back-btn">View Message</button>
<button type="button" class="btn btn-md btn-primary" id="reply-send-btn" disabled>Reply</button>
{% endset %}
{% include "components/modal.njk" %}
{% endblock %}

{% block pageJS %}
<script src="/js/contact-non-members.js" defer></script>
{% endblock %}
