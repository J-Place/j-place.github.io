---
permalink: /club-central/manage-members.html
title: Manage Current Members | U.S. Masters Swimming
pageTitle: Manage Current Members
breadcrumbs:
  - url: "/home"
    label: "Home"
  - url: "/club-central"
    label: "Club Central"
  - url: "/club-central/club-dashboard.html"
    label: "Club Dashboard"
  - url: "/club-central/club-dashboard/club-manage.html"
    label: "Manage Club"
breadcrumbTitle: "Manage Current Members"
---
{% extends "layouts/base.njk" %}

{% block pageCSS %}
<link rel="stylesheet" href="https://www.usms.org/styles/clubDetail.min.css">
<link rel="stylesheet" href="https://www.usms.org/styles/registration.min.css">
<link rel="stylesheet" href="https://www.usms.org/styles/mastersAddons.min.css">
<link rel="stylesheet" href="/css/Forms/Payment.css">
<link rel="stylesheet" href="/css/Club/manage-members.css">
{% endblock %}

{% block breadcrumb %}
{% include "partials/Common/Breadcrumb.njk" %}
{% endblock %}

{% block pageHeader %}
<div class="section section-full bg-gray">
  <div class="usms-container p-tb-10">
    <div class="row">
      <div class="col-xs-12">
        <header class="page-title">
          <h1>Manage Current Members</h1>
          <h2 id="members-club-name" style="display:none"></h2>
        </header>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block content %}
<script type="application/json" id="members-local-data">{{ membersLocal.members | dump | safe }}</script>
<script type="application/json" id="clubs-local-data">{{ clubsLocal.clubs | dump | safe }}</script>

<div class="section section-full bg-gray">
  <div class="usms-container">
    <p class="members-lead">These are the active members currently registered with your club.</p>
  </div>
</div>

<div class="section section-full bg-gray">
  <div class="usms-container form__container p-tb-10">

        <div id="members-no-club" class="members-notice" style="display:none;">
          <p>No club selected. Please return to the <a href="/club-central/club-dashboard.html">Club Dashboard</a>.</p>
        </div>

        <div class="members-layout">
        <div id="members-content">

          <div class="members-select-all-row">
            <label class="members-select-all-label"><input type="checkbox" id="select-all-expiring"> Select All</label>
            <span class="members-pending-legend visible-xs-inline">* Pending Waiver</span>
          </div>

          <div class="table-responsive">
            <table class="table members-table members-table--checkable">
              <thead>
                <tr>
                  <th class="col-checkbox"></th>
                  <th>Name <button class="members-sort-btn is-active" data-sort="lastName" aria-label="Sort A to Z"><span class="members-sort-icon"><i class="fas fa-sort members-sort-base" aria-hidden="true"></i><i class="fas fa-sort-up members-sort-overlay" aria-hidden="true"></i></span></button></th>
                  <th><span class="hidden-xs">Permanent </span>ID</th>
                  <th>Membership Type <button class="members-sort-btn" data-sort="status" aria-label="Sort A to Z"><span class="members-sort-icon"><i class="fas fa-sort members-sort-base" aria-hidden="true"></i><i class="fas fa-sort-up members-sort-overlay" aria-hidden="true"></i></span></button></th>
                  <th>Event License <button class="members-sort-btn" data-sort="membershipType" aria-label="Sort A to Z"><span class="members-sort-icon"><i class="fas fa-sort members-sort-base" aria-hidden="true"></i><i class="fas fa-sort-up members-sort-overlay" aria-hidden="true"></i></span></button></th>
                  <th>Registered <button class="members-sort-btn" data-sort="registrationDate" aria-label="Sort A to Z"><span class="members-sort-icon"><i class="fas fa-sort members-sort-base" aria-hidden="true"></i><i class="fas fa-sort-up members-sort-overlay" aria-hidden="true"></i></span></button></th>
                  <th>Expires <button class="members-sort-btn" data-sort="expirationDate" aria-label="Sort A to Z"><span class="members-sort-icon"><i class="fas fa-sort members-sort-base" aria-hidden="true"></i><i class="fas fa-sort-up members-sort-overlay" aria-hidden="true"></i></span></button></th>
                </tr>
              </thead>
              <tbody id="tbody-members"></tbody>
            </table>
          </div>

        </div>{# /members-content #}

      <div class="renew__form-body masters-addons" id="payment-section">
        <form class="form-membership-length form-horizontal">
          <input type="hidden" name="dataDesc"><input type="hidden" name="dataValue">
          <h3 class="payment-info___form-header payment-section__heading m-b-30">Enter Payment Details</h3>
          <div class="payment-info__form-summary">
            <p class="payment-info__line-item payment-info__line-item--usms" id="payment-license-line" style="display:none">
              <span id="payment-license-count">0</span> Standard Membership &times; $75.00
              <span class="payment-info__line-item--price" id="payment-license-subtotal">$0.00</span>
            </p>
            <p class="payment-info__line-item payment-info__line-item--total">
              Total: <span class="payment-info__line-item--price" id="payment-total">$0.00</span>
            </p>
          </div>
          <div class="card__content addons-payment__fields">
            <div class="form-group card-name">
              <div class="col-xs-12">
                <label for="cardName" class="font-weight-bold">Name on Card</label>
                <div><span class="help-block help-block--cardName">Please enter a value for cardName</span><input type="text" class="form-control" name="cardName" id="cardName" autocomplete="on" maxlength="100" value=""><span class="glyphicon form-control-feedback glyphicon--cardName" aria-hidden="true"></span></div>
              </div>
            </div>
            <div class="form-group card-number">
              <div class="col-xs-12 col-sm-7">
                <label for="cardNumberID" class="font-weight-bold">Card Number</label>
                <div><span class="help-block help-block--cardNumberID">Please enter a valid credit card number</span><input type="text" class="form-control" name="cardNumberID" id="cardNumberID" autocomplete="on" maxlength="100" value=""><span class="glyphicon form-control-feedback glyphicon--cardNumberID" aria-hidden="true"></span></div>
              </div>
              <div class="col-xs-5 col-sm-2 form-membership-length__security-code">
                <label for="cardCodeID" class="font-weight-bold">Security Code</label>
                <div><span class="help-block help-block--cardCodeID">Please enter a value for Security Code</span><input type="text" class="form-control" name="cardCodeID" id="cardCodeID" autocomplete="on" maxlength="100" value=""><span class="glyphicon form-control-feedback glyphicon--cardCodeID" aria-hidden="true"></span></div>
              </div>
              <div class="col-xs-7 col-sm-3">
                <label for="expiration" class="font-weight-bold">Expiration (mm/yy)</label>
                <div><span class="help-block help-block--expiration">Please enter a valid expiration date</span><input type="text" class="form-control" name="expiration" id="expiration" autocomplete="on" maxlength="5" value=""><span class="glyphicon form-control-feedback glyphicon--expiration" aria-hidden="true"></span></div>
              </div>
            </div>
            <div class="form-group card-zip">
              <div class="col-xs-8 col-sm-4">
                <label for="cardZipID" class="font-weight-bold">Billing Zip</label>
                <div><span class="help-block help-block--cardZipID">Please enter a valid billing zip</span><input type="text" class="form-control" name="cardZipID" id="cardZipID" autocomplete="on" maxlength="100" value=""><span class="glyphicon form-control-feedback glyphicon--cardZipID" aria-hidden="true"></span></div>
              </div>
            </div>
          </div>
          <div class="form-group agree-terms">
            <div class="col-xs-12">
              <span class="help-block help-block--agree-terms">You need to agree to the terms to complete your registration.</span>
              <label id="agreeTerms__label" class="checkbox-label disabled" for="agreeTerms">
                <div class="checkbox-container"><input type="checkbox" name="agree-terms" id="agreeTerms" value=""><span class="checkbox__placeholder"></span></div>
              </label>
              <span class="font-weight-bold">I understand that this transaction will take effect immediately and is non-refundable, non-transferable, and these memberships will expire on December 31, 2026.</span>
            </div>
          </div>
          <p id="payment-no-members-error" class="payment-error" style="display:none;">Please select at least one member to register before submitting payment.</p>
          <button type="button" id="register-button" class="btn btn-primary btn-large text-uppercase pull-left membership-length__submit">Register Selected</button>
        </form>
      </div>{# /renew__form-body #}
        </div>{# /members-layout #}

  </div>{# /usms-container form__container #}
</div>{# /section #}
{% endblock %}

{% block pageJS %}
<script src="/js/manage-members.js" defer></script>
{% endblock %}
