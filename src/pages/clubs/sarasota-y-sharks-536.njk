{% extends "layouts/base.njk" %}
{% block pageCSS %}
<link rel="stylesheet" href="https://www.usms.org/styles/clubDetail.min.css">
{% endblock %}
{% block breadcrumb %}
{% include "partials/Common/Breadcrumb.njk" %}
{% endblock %}
{% block content %}

<div class="section section-full p-b-10">
  <iframe
    src="https://maps.google.com/maps?q=Selby+Aquatic+Center+8501+Potter+Park+Drive+Sarasota+FL+34238&output=embed"
    style="height: 350px; width: 100%; border: 0;"
    allowfullscreen=""
    loading="lazy"
    title="Selby Aquatic Center map"></iframe>
</div>

<div class="section section-full p-b-10">
  <div class="usms-container p-tb-10">
    <div class="row">

      <div class="col-xs-12 col-md-8">
        <div class="club__description">
          <h1 class="club__header">Sarasota Sharks Masters</h1>
          <p>The Sharks provide organized workouts, competitions, clinics, and workshops for adults aged 18 and over. We currently have more than 350 members. We welcome ALL adult swimmers (fitness, triathlete, competitive, noncompetitive, open water). We're all about helping swimmers improve fitness, train for specific goals, and providing active support for a healthy lifestyle through friendship and camaraderie.</p>
          <h3 class="club__practice-info">Practice Information</h3>
          <p>Visit the club website for workout info</p>
        </div>

        <div class="club__locations">
          <div class="club-location">
            <div class="club-location__left-container">
              <div class="club-location__map-pin">
                <img src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/images/map/marker_orange.png?rev=9b3b34aaf0ca468990121aa0a0afdcb9">
                <p class="club-location__map-pin--distance">70</p>
              </div>
            </div>
            <div class="club-location__right-container">
              <div class="club-location__address">
                <a href="https://maps.google.com/?q=8501+Potter+Park+Drive+Sarasota+FL+34238" target="_blank">
                  <h5 class="club-location__address--name">Selby Aquatic Center</h5>
                  <p class="club-location__address--street">8501 Potter Park Drive</p>
                  <p class="club-location__address--city-state-zip">Sarasota, FL 34238</p>
                </a>
              </div>
              <div class="club-location__facilities">
                <div class="club-location__facility">
                  <div class="club-location__facility--length">50m</div>
                  <div class="club-location__facility--environment">Outdoor Pool</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row club-contact-form">
          <div class="col-xs-12 col-md-10">
            <h3 class="club__workout-header club-contact-form__header">Contact Sarasota Sharks Masters</h3>
            <div class="form-container">
              <form>
                <div class="sc-form__container form__container--club-contact">
                  <div class="row">
                    <div class="col-sm-6">
                      <label for="firstName">First Name</label>
                      <input id="firstName" name="firstName" type="text" maxlength="255">
                    </div>
                    <div class="col-sm-6">
                      <label for="lastName">Last Name</label>
                      <input id="lastName" name="lastName" type="text" maxlength="255">
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-10">
                      <label for="email">Email Address</label>
                      <input id="email" name="email" type="email" maxlength="255">
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-8">
                      <label for="phone">Phone Number</label>
                      <input id="phone" name="phone" type="tel" maxlength="255">
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-8 is-member">
                      <label class="sc-form__radio-inline--label">Are you a current USMS member?</label>
                      <label><input type="radio" name="member" value="Yes"> Yes</label>
                      <label><input type="radio" name="member" value="No"> No</label>
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-8 club-interest">
                      <div class="sc-form__select-group">
                        <label for="lookingFor" class="sc-form__select--label">What are you looking for?</label>
                        <select id="lookingFor" name="lookingFor">
                          <option value=""></option>
                          <option value="Attend a practice">Attend a practice</option>
                          <option value="Find a coach">Find a coach</option>
                          <option value="Join a club">Join a club</option>
                        </select>
                      </div>
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-10">
                      <label for="message">Message</label>
                      <textarea id="message" name="message" rows="4" maxlength="512"></textarea>
                    </div>
                  </div>
                  <div class="row">
                    <div class="col-sm-6">
                      <div class="sc-form__checkbox-group">
                        <label>
                          <input type="checkbox" name="emailOptIn" value="true"> Sign up for updates from USMS
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="row btn-submit--initial">
                  <div class="sc-form__footer">
                    <input value="Submit" type="submit" class="btn btn-primary btn-large btn-submit--member">
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xs-12 col-md-4">
        <button class="btn btn-usms btn-large club__join-now">Join USMS Now</button>
        <div class="club-website">
          <a href="https://www.gomotionapp.com/team/flsysst/page/masters/practicescheduleworkouts" class="btn btn-link" target="_blank">Visit Club Website</a>
        </div>
        <div class="club-detail2__badges">
          <h4 class="club-detail2__badges--header">Club Designations</h4>
          <ul class="club-detail2__badges-list list--nostyle">
            <li class="club-detail2__badges-item">
              <a href="#" data-toggle="modal" data-target="#badgeCoach">
                <img src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-coach.png?h=321&w=350&rev=635d566be36d4cdcadc27626fde72b68&hash=82DC6C945E565F72016697C779170E0D">
                <p>USMS Certified Coach</p>
              </a>
            </li>
            <li class="club-detail2__badges-item">
              <a href="#" data-toggle="modal" data-target="#badgeAlts">
                <img src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-alts.png?h=321&w=350&rev=3b08e5ab609141ad9a924f61da33bc96&hash=CEA3F6989ED4F63208DFA8A8AC32352B">
                <p>USMS Certified ALTS Instructor</p>
              </a>
            </li>
            <li class="club-detail2__badges-item">
              <a href="#" data-toggle="modal" data-target="#badgeGold">
                <img src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-gold.png?h=321&w=350&rev=31ba632063c64b5ab6621a05722f46ad&hash=F7D51558DD678357C7C8CB607BA359BE">
                <p>USMS Certified Gold Club</p>
              </a>
            </li>
          </ul>
        </div>
        <div class="club-social-links">
          <h4 class="club-social-links__header">Connect With Us</h4>
          <div class="club-social-links__content">
            <ul class="social-share-icons list--nostyle">
              <li class="social-share-icons__item">
                <a href="https://www.facebook.com/SharksMasters" target="_blank" title="Facebook">
                  <i class="fa-brands fa-facebook-f"></i>
                </a>
              </li>
              <li class="social-share-icons__item">
                <a href="https://www.twitter.com/SharksMasters" target="_blank" title="Twitter">
                  <i class="fa-brands fa-x-twitter"></i>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

{% set modalId = "badgeCoach" %}
{% set modalModifier = "cta-modal--club-badge" %}
{% set modalBody %}
<div class="cta-col--center">
  <div class="club-badge--image">
    <img style="width:80px;" src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-coach.png?h=321&w=350&rev=635d566be36d4cdcadc27626fde72b68&hash=82DC6C945E565F72016697C779170E0D">
  </div>
  <h4 class="club-badge--header">USMS Certified Coaches</h4>
  <p class="club-badge--content">These coaches have furthered their Masters coaching education and have passed the certification exam.</p>
</div>
{% endset %}
{% include "components/modal.njk" %}

{% set modalId = "badgeAlts" %}
{% set modalModifier = "cta-modal--club-badge" %}
{% set modalBody %}
<div class="cta-col--center">
  <div class="club-badge--image">
    <img style="width:80px;" src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-alts.png?h=321&w=350&rev=3b08e5ab609141ad9a924f61da33bc96&hash=CEA3F6989ED4F63208DFA8A8AC32352B">
  </div>
  <h4 class="club-badge--header">USMS Certified ALTS Instructor</h4>
  <p class="club-badge--content">These instructors have furthered their swim-lessons instruction education and have passed the certification exam.</p>
</div>
{% endset %}
{% include "components/modal.njk" %}

{% set modalId = "badgeGold" %}
{% set modalModifier = "cta-modal--club-badge" %}
{% set modalBody %}
<div class="cta-col--center">
  <div class="club-badge--image">
    <img style="width:80px;" src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/developers/images/club%20detail/club-badge-gold.png?h=321&w=350&rev=31ba632063c64b5ab6621a05722f46ad&hash=F7D51558DD678357C7C8CB607BA359BE">
  </div>
  <h4 class="club-badge--header">USMS Certified Gold Club</h4>
  <p class="club-badge--content">Gold Clubs have a U.S. Masters Swimming–certified coach on staff, participate in fitness events, and offer a free trial to potential members.</p>
</div>
{% endset %}
{% include "components/modal.njk" %}

{% endblock %}
