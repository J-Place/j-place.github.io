{% extends "layouts/swimmer-library.njk" %}
{% block content %}
<section class="section section-full">
  <div class="usms-container">
    <div class="row">
      <div class="col-xs-12">
        <div class="image-rendering image-left swimmer-magazine__header-image">
          <img src="https://www-usms-hhgdctfafngha6hr.z01.azurefd.net/-/media/usms/jbw%20magazine/swimmermastko.svg?rev=6457b089043041cd82475f86d24f6a85&hash=0D060E4375694A995AF78FCF7E02833E" alt="SWIMMER Magazine">
        </div>
        <div class="html-container">
          <p>SWIMMER is the official magazine of U.S. Masters Swimming. Featuring swim tips from world-class coaches and athletes, race strategy, training plans, nutrition advice, and member profiles, SWIMMER is the perfect resource for Masters swimmers of all ability levels.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function handleYearChange(event) {
    var selectedYear = event.target.value;
    if (selectedYear !== '2026' && selectedYear !== '2025') return;
    var allIssues = document.querySelectorAll('.magazine-issue');
    allIssues.forEach(function(issue) {
      if (issue.getAttribute('data-year') === selectedYear) {
        issue.style.display = 'block';
        issue.classList.remove('fade');
      } else {
        issue.style.display = 'none';
        issue.classList.add('fade');
      }
    });
  }
</script>

<div class="usms-container swimmer-library">
  <div class="issue-selector">
    <select class="current-year" onchange="handleYearChange(event)">
