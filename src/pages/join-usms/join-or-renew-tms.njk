{% extends "layouts/base.njk" %}
{% block pageCSS %}
<link rel="stylesheet" href="/css/join-tms.css">
{% endblock %}
{% block breadcrumb %}
{% include "partials/breadcrumb.njk" %}
{% endblock %}
{% block content %}
{% include "partials/join-tms-content.njk" %}
{% endblock %}
{% block pageJS %}
<script>
  (function() {
    function pullUpImageCol() {
      var textCol = document.getElementById('hero-text-col');
      var imgCol = document.getElementById('hero-img-col');
      if (textCol && imgCol) {
        imgCol.style.marginTop = '-' + textCol.offsetHeight + 'px';
      }
    }
    document.addEventListener('DOMContentLoaded', pullUpImageCol);
    window.addEventListener('resize', pullUpImageCol);
  })();
</script>
<script>
  (function() {
    document.getElementById('sign-up__button').addEventListener('click', function(e) {
      e.preventDefault();
      const data = { email: document.querySelector('.sign-up #emailAddress').value };
      fetch('/apis/v1/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        mode: 'cors',
        credentials: 'include'
      })
      .then(response => response.json())
      .then(data => handleFormSuccess(data))
      .catch(error => console.error('Error:', error));
    });
  })();

  function handleFormSuccess(response) {
    if (response && response.data && response.data.SignedUp) {
      document.querySelector('.sign-up__container').classList.add('sign-up__container--hide');
      setTimeout(function() {
        document.querySelector('.sign-up__container').style.display = 'none';
        document.querySelector('.sign-up__confirmation').style.display = 'block';
        setTimeout(function() {
          document.querySelector('.sign-up__confirmation').classList.add('sign-up__confirmation--shown');
        }, 50);
      }, 500);
    } else if (response.error === 'Invalid email') {
      document.querySelector('.sign-up__validation').style.display = 'block';
    }
  }
</script>
<script>
  (function() {
    var rows = document.querySelectorAll('.tms-benefits');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('tms-benefits--visible');
        } else {
          entry.target.classList.remove('tms-benefits--visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -20% 0px' });
    rows.forEach(function(row) { observer.observe(row); });
  })();
</script>
{% endblock %}
